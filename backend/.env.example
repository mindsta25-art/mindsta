# ==========================================
# MINDSTA BACKEND ENVIRONMENT CONFIGURATION
# ==========================================

# Application
NODE_ENV=development
PORT=3000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/mindsta
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mindsta?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-key-change-this-in-production

# ==========================================
# EMAIL CONFIGURATION (Resend - Production)
# ==========================================

# Resend API (primary - works on all hosting platforms including Render)
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM=Mindsta <noreply@yourdomain.com>

# ==========================================
# EMAIL CONFIGURATION (SMTP - Local dev fallback)
# ==========================================
EMAIL_PORT=587
EMAIL_SECURE=false

# Authentication
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Sender Information
EMAIL_FROM=Mindsta <noreply@mindsta.com>

# Advanced Email Settings (optional)
# Connection Pooling - keeps connections open for faster email sending
EMAIL_POOL=true
EMAIL_MAX_CONNECTIONS=5
EMAIL_MAX_MESSAGES=100

# Rate Limiting - limits number of emails per second
EMAIL_RATE_LIMIT=5
EMAIL_RATE_DELTA=1000

# Retry Configuration - automatically retries failed emails
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=1000

# ==========================================
# EMAIL PROVIDER SETUP GUIDES
# ==========================================

# GMAIL SETUP:
# 1. Enable 2-Step Verification in your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an "App Password" for "Mail"
# 4. Use the generated 16-character password as EMAIL_PASSWORD
# 5. Set EMAIL_SERVICE=gmail or use:
#    EMAIL_HOST=smtp.gmail.com
#    EMAIL_PORT=587
#    EMAIL_SECURE=false

# OUTLOOK/HOTMAIL SETUP:
# 1. Enable 2-Step Verification in Microsoft Account
# 2. Generate App Password if required
# 3. Set EMAIL_SERVICE=outlook or use:
#    EMAIL_HOST=smtp-mail.outlook.com
#    EMAIL_PORT=587
#    EMAIL_SECURE=false

# CUSTOM SMTP SETUP:
# 1. Leave EMAIL_SERVICE empty
# 2. Set EMAIL_HOST to your SMTP server
# 3. Set EMAIL_PORT (usually 587 for TLS or 465 for SSL)
# 4. Set EMAIL_SECURE=true for port 465, false for port 587
# 5. Set EMAIL_USER and EMAIL_PASSWORD

# ==========================================
# PAYMENT GATEWAY CONFIGURATION
# ==========================================

# Paystack (Nigerian Payment Gateway)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# ==========================================
# FRONTEND URL
# ==========================================
FRONTEND_URL=http://localhost:5173

# ==========================================
# FILE UPLOAD CONFIGURATION
# ==========================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ==========================================
# SESSION CONFIGURATION
# ==========================================
SESSION_SECRET=your-session-secret-key-change-this
SESSION_TIMEOUT=3600000

# ==========================================
# REDIS (Optional - for caching)
# ==========================================
# REDIS_URL=redis://localhost:6379

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info

# ==========================================
# CORS CONFIGURATION
# ==========================================
CORS_ORIGIN=http://localhost:5173

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# ADMIN ACCOUNT (Initial Setup)
# ==========================================
ADMIN_EMAIL=admin@mindsta.com
ADMIN_PASSWORD=changeme
